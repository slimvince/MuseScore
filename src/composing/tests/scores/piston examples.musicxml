    <!-- ============================================================
         EX. 222 (p.118) — Cadential 6/4 chord
         Four progressions each ending (I64) → V
         Preceding chords: IV, II, VI, I
         Tests: I6/4 (second inversion, G in bass) — the most common
                second inversion type
         ============================================================ -->

    <!-- New section: time sig change, key stays C major -->
    <measure number="3">
      <attributes>
        <time><beats>2</beats><beat-type>2</beat-type></time>
      </attributes>

      <!-- Pattern A: IV → (I64) → V -->
      <!-- IV: F/A/C/F -->
      <note><pitch><step>C</step><octave>5</octave></pitch>
        <duration>4</duration><type>half</type><staff>1</staff><voice>1</voice></note>
      <note><chord/><pitch><step>A</step><octave>4</octave></pitch>
        <duration>4</duration><type>half</type><staff>1</staff><voice>1</voice></note>
      <note><chord/><pitch><step>F</step><octave>4</octave></pitch>
        <duration>4</duration><type>half</type><staff>1</staff><voice>2</voice></note>
      <note><pitch><step>F</step><octave>3</octave></pitch>
        <duration>4</duration><type>half</type><staff>2</staff><voice>3</voice></note>

      <!-- I64: G in bass, C/E/G — second inversion tonic -->
      <note><pitch><step>C</step><octave>5</octave></pitch>
        <duration>4</duration><type>half</type><staff>1</staff><voice>1</voice></note>
      <note><chord/><pitch><step>G</step><octave>4</octave></pitch>
        <duration>4</duration><type>half</type><staff>1</staff><voice>1</voice></note>
      <note><chord/><pitch><step>E</step><octave>4</octave></pitch>
        <duration>4</duration><type>half</type><staff>1</staff><voice>2</voice></note>
      <note><pitch><step>G</step><octave>3</octave></pitch>
        <duration>4</duration><type>half</type><staff>2</staff><voice>3</voice></note>
    </measure>

    <measure number="4">
      <!-- V: G/B/D/G -->
      <note><pitch><step>D</step><octave>5</octave></pitch>
        <duration>4</duration><type>half</type><staff>1</staff><voice>1</voice></note>
      <note><chord/><pitch><step>B</step><octave>4</octave></pitch>
        <duration>4</duration><type>half</type><staff>1</staff><voice>1</voice></note>
      <note><chord/><pitch><step>D</step><octave>4</octave></pitch>
