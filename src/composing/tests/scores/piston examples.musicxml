  <part id="P1">

    <!-- ============================================================
         EX. 150 (p.89) — C major, SATB
         Roman numerals: V6  I  I6  IV  I  I6  II6  V
         Tests: V6 (G/B bass), I6 (C/E bass), II6 (D/F bass)
         ============================================================ -->

    <!-- Measure 1: V6 (G/B) — I (C) — I6 (C/E) — IV (F) -->
    <measure number="1">
      <attributes>
        <divisions>4</divisions>
        <key><fifths>0</fifths><mode>major</mode></key>
        <time><beats>4</beats><beat-type>4</beat-type></time>
        <staves>2</staves>
        <clef number="1"><sign>G</sign><line>2</line></clef>
        <clef number="2"><sign>F</sign><line>4</line></clef>
      </attributes>

      <!-- Chord 1: V6 in C major — B in bass, G/B/D upper -->
      <!-- Soprano=D5, Alto=G4, Tenor=D4, Bass=B2 -->
      <note><pitch><step>D</step><octave>5</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>1</staff><voice>1</voice></note>
      <note><chord/><pitch><step>G</step><octave>4</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>1</staff><voice>1</voice></note>
      <note><chord/><pitch><step>D</step><octave>4</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>1</staff><voice>2</voice></note>
      <note><pitch><step>B</step><octave>2</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>2</staff><voice>3</voice></note>

      <!-- Chord 2: I in C major — C/E/G/C -->
      <!-- Soprano=E5, Alto=G4, Tenor=E4, Bass=C3 -->
      <note><pitch><step>E</step><octave>5</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>1</staff><voice>1</voice></note>
      <note><chord/><pitch><step>G</step><octave>4</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>1</staff><voice>1</voice></note>
      <note><chord/><pitch><step>E</step><octave>4</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>1</staff><voice>2</voice></note>
      <note><pitch><step>C</step><octave>3</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>2</staff><voice>3</voice></note>

      <!-- Chord 3: I6 in C major — E in bass, C/E/G upper -->
      <!-- Soprano=C5, Alto=G4, Tenor=C4, Bass=E3 -->
      <note><pitch><step>C</step><octave>5</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>1</staff><voice>1</voice></note>
      <note><chord/><pitch><step>G</step><octave>4</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>1</staff><voice>1</voice></note>
      <note><chord/><pitch><step>C</step><octave>4</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>1</staff><voice>2</voice></note>
      <note><pitch><step>E</step><octave>3</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>2</staff><voice>3</voice></note>

      <!-- Chord 4: IV in C major — F/A/C root position -->
      <!-- Soprano=C5, Alto=A4, Tenor=F4, Bass=F3 -->
      <note><pitch><step>C</step><octave>5</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>1</staff><voice>1</voice></note>
      <note><chord/><pitch><step>A</step><octave>4</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>1</staff><voice>1</voice></note>
      <note><chord/><pitch><step>F</step><octave>4</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>1</staff><voice>2</voice></note>
      <note><pitch><step>F</step><octave>3</octave></pitch>
        <duration>4</duration><type>quarter</type><staff>2</staff><voice>3</voice></note>
    </measure>

    <!-- Measure 2: I (C) — I6 (C/E) — II6 (D/F) — V (G) -->
    <measure number="2">
