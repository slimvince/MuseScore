<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE score-partwise PUBLIC "-//Recordare//DTD MusicXML 3.1 Partwise//EN"
  "http://www.musicxml.org/dtds/partwise.dtd">
<!--
  Chord Analyzer — Resolution-Bias Context Tests
  ================================================
  Twelve measures in four groups.  Each group exercises one quality-guided
  resolution bias.  Measures are consecutive (no separator rests) so that
  the test harness can thread both previousRootPc AND previousQuality from
  one measure to the next and observe the bias firing on the resolution chord.

  Group 1 — viio7 → I  (Bdim7 → C major, C major)
  Group 2 — ii∅7  → V  (Am → Bm7b5 → E major)           [A minor]
  Group 3 — I+    → I  (C major → C+ → C major)           [C major]
  Group 4 — V7 → viio7 → I  (G7 → Bdim7 → C major)       [C major]
-->
<score-partwise version="3.1">
  <part-list>
    <score-part id="P1">
      <part-name>Context Progressions</part-name>
    </score-part>
  </part-list>
  <part id="P1">
    <!-- ── Group 1: viio7 → I in C major ────────────────────────────────── -->
    <!-- M1  C major — tonic context -->
    <measure number="1"><attributes><divisions>1</divisions><key><fifths>0</fifths><mode>major</mode></key><time><beats>4</beats><beat-type>4</beat-type></time><clef><sign>G</sign><line>2</line></clef></attributes><harmony print-frame="no" analysisKind="major"><root><root-step>C</root-step></root><kind text="C">none</kind></harmony><note><pitch><step>C</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>E</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>G</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- M2  Bdim7 — viio7 chord; sets previousQuality=Diminished -->
    <measure number="2"><attributes><key><fifths>0</fifths><mode>major</mode></key></attributes><harmony print-frame="no" analysisKind="diminished-seventh"><root><root-step>B</root-step></root><kind text="Bdim7">none</kind></harmony><note><pitch><step>B</step><octave>3</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>D</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>F</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>A</step><alter>-1</alter><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- M3  C major — I resolution; Diminished→+1 bias fires for C -->
    <measure number="3"><attributes><key><fifths>0</fifths><mode>major</mode></key></attributes><harmony print-frame="no" analysisKind="major"><root><root-step>C</root-step></root><kind text="C">none</kind></harmony><note><pitch><step>C</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>E</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>G</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- ── Group 2: ii∅7 → V in A minor ─────────────────────────────────── -->
    <!-- M4  Am — tonic i context; key changes to A minor -->
    <measure number="4"><attributes><key><fifths>0</fifths><mode>minor</mode></key></attributes><harmony print-frame="no" analysisKind="minor"><root><root-step>A</root-step></root><kind text="Am">none</kind></harmony><note><pitch><step>A</step><octave>3</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>C</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>E</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- M5  Bm7b5 — ii∅7 chord; sets previousQuality=HalfDiminished -->
    <measure number="5"><attributes><key><fifths>0</fifths><mode>minor</mode></key></attributes><harmony print-frame="no" analysisKind="half-diminished"><root><root-step>B</root-step></root><kind text="Bm7b5">none</kind></harmony><note><pitch><step>B</step><octave>3</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>D</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>F</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>A</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- M6  E major — V resolution; HalfDim→+5 bias fires for E (B+5=E) -->
    <measure number="6"><attributes><key><fifths>0</fifths><mode>minor</mode></key></attributes><harmony print-frame="no" analysisKind="major"><root><root-step>E</root-step></root><kind text="E">none</kind></harmony><note><pitch><step>E</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>G</step><alter>1</alter><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>B</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- ── Group 3: I+ → I in C major ───────────────────────────────────── -->
    <!-- M7  C major — tonic context; key returns to C major -->
    <measure number="7"><attributes><key><fifths>0</fifths><mode>major</mode></key></attributes><harmony print-frame="no" analysisKind="major"><root><root-step>C</root-step></root><kind text="C">none</kind></harmony><note><pitch><step>C</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>E</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>G</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- M8  C+ — augmented passing chord; sets previousQuality=Augmented -->
    <measure number="8"><attributes><key><fifths>0</fifths><mode>major</mode></key></attributes><harmony print-frame="no" analysisKind="augmented"><root><root-step>C</root-step></root><kind text="C+">none</kind></harmony><note><pitch><step>C</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>E</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>G</step><alter>1</alter><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- M9  C major — I return; Augmented→same-root bias fires for C -->
    <measure number="9"><attributes><key><fifths>0</fifths><mode>major</mode></key></attributes><harmony print-frame="no" analysisKind="major"><root><root-step>C</root-step></root><kind text="C">none</kind></harmony><note><pitch><step>C</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>E</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>G</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- ── Group 4: V7 → viio7 → I in C major ───────────────────────────── -->
    <!-- M10  G7 — dominant 7th -->
    <measure number="10"><attributes><key><fifths>0</fifths><mode>major</mode></key></attributes><harmony print-frame="no" analysisKind="dominant"><root><root-step>G</root-step></root><kind text="G7">none</kind></harmony><note><pitch><step>G</step><octave>3</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>B</step><octave>3</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>D</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>F</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- M11  Bdim7 — viio7; sets previousQuality=Diminished -->
    <measure number="11"><attributes><key><fifths>0</fifths><mode>major</mode></key></attributes><harmony print-frame="no" analysisKind="diminished-seventh"><root><root-step>B</root-step></root><kind text="Bdim7">none</kind></harmony><note><pitch><step>B</step><octave>3</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>D</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>F</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>A</step><alter>-1</alter><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- M12  C major — I resolution; Diminished→+1 bias fires for C -->
    <measure number="12"><attributes><key><fifths>0</fifths><mode>major</mode></key></attributes><harmony print-frame="no" analysisKind="major"><root><root-step>C</root-step></root><kind text="C">none</kind></harmony><note><pitch><step>C</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>E</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>G</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- ── Group 5: Tillägnan intro — D major (2 sharps) ─────────────────── -->
    <!-- M13  Dadd9/A — I/5 in D major; bass=A (5th), added 9th (E) -->
    <measure number="13"><attributes><key><fifths>2</fifths><mode>major</mode></key><time><beats>4</beats><beat-type>4</beat-type></time></attributes><harmony print-frame="no" analysisKind="other"><root><root-step>D</root-step></root><kind text="Dadd9">none</kind><bass><bass-step>A</bass-step></bass></harmony><note><pitch><step>A</step><octave>2</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>F</step><alter>1</alter><octave>3</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>D</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>E</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>A</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- M14  Cmaj9/A — chromatic chord in D major; C natural is non-diatonic -->
    <measure number="14"><attributes><key><fifths>2</fifths><mode>major</mode></key></attributes><harmony print-frame="no" analysisKind="other"><root><root-step>C</root-step></root><kind text="Cmaj9">none</kind><bass><bass-step>A</bass-step></bass></harmony><note><pitch><step>A</step><octave>2</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>G</step><octave>3</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>D</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>E</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>C</step><octave>5</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- M15  Dadd9/A — repeat of M13 -->
    <measure number="15"><attributes><key><fifths>2</fifths><mode>major</mode></key></attributes><harmony print-frame="no" analysisKind="other"><root><root-step>D</root-step></root><kind text="Dadd9">none</kind><bass><bass-step>A</bass-step></bass></harmony><note><pitch><step>A</step><octave>2</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>F</step><alter>1</alter><octave>3</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>D</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>E</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>A</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- M16  Cmaj9/A — repeat of M14 -->
    <measure number="16"><attributes><key><fifths>2</fifths><mode>major</mode></key></attributes><harmony print-frame="no" analysisKind="other"><root><root-step>C</root-step></root><kind text="Cmaj9">none</kind><bass><bass-step>A</bass-step></bass></harmony><note><pitch><step>A</step><octave>2</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>G</step><octave>3</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>D</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>E</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>C</step><octave>5</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
    <!-- M17  DM7 — IM7 in D major -->
    <measure number="17"><attributes><key><fifths>2</fifths><mode>major</mode></key></attributes><harmony print-frame="no" analysisKind="major-seventh"><root><root-step>D</root-step></root><kind text="DM7">none</kind></harmony><note><pitch><step>D</step><octave>3</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>A</step><octave>3</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>C</step><alter>1</alter><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>D</step><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note><note><chord/><pitch><step>F</step><alter>1</alter><octave>4</octave></pitch><duration>1</duration><type>quarter</type></note></measure>
